{
  "name": "campussync",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "firebase:cli": "npx --yes firebase-tools",
    "firebase:login": "npx --yes firebase-tools login",
    "firebase:whoami": "npx --yes firebase-tools login:list",
    "deploy:rules": "npx --yes firebase-tools deploy --project campussync-c3d3c --only firestore:rules",
    "deploy:indexes": "npx --yes firebase-tools deploy --project campussync-c3d3c --only firestore:indexes",
    "deploy:hosting": "npm run build && npx --yes firebase-tools deploy --project campussync-c3d3c --only hosting:campussync-c3d3c",
    "deploy:preview": "npm run build && npx --yes firebase-tools hosting:channel:deploy preprod --project campussync-c3d3c --site campussync-c3d3c",
    "deploy:all": "npm run build && npx --yes firebase-tools deploy --project campussync-c3d3c --only firestore:rules,firestore:indexes,hosting:campussync-c3d3c"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "firebase": "^10.12.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.13"
  }
}
