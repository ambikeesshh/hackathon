// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
// Updated: Fixed userRole for new users

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      // Handle case where user profile doesn't exist yet
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.role;
    }

    function hasValidRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.role in ['student', 'faculty', 'admin'];
    }

    function isStudent()  { return isSignedIn() && hasValidRole() && userRole() == 'student'; }
    function isFaculty()  { return isSignedIn() && hasValidRole() && userRole() == 'faculty'; }
    function isAdmin()    { return isSignedIn() && hasValidRole() && userRole() == 'admin'; }
    function isFacultyOrAdmin() { return isFaculty() || isAdmin(); }

    // Valid status values
    function isValidStatus(status) {
      return status in ['free', 'occupied', 'partial', 'reserved'];
    }

    // ── /users ─────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own profile
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow create on registration (new doc only)
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Only admin can update roles
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── /rooms ─────────────────────────────────────────────────
    match /rooms/{roomId} {
      // All signed-in users can read rooms
      allow read: if isSignedIn();

      // Only faculty or admin can update room status fields
      // Must validate: status enum, updatedBy must equal current user
      allow update: if isFacultyOrAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt', 'updatedBy', 'autoResetAt', 'note', 'reservedBy', 'reservedUntil'])
        && request.resource.data.updatedBy == request.auth.uid
        && isValidStatus(request.resource.data.status);

      // Only admin can create / delete rooms
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── /activityLogs ──────────────────────────────────────────────────
    match /activityLogs/{logId} {
      // Faculty/admin can write logs
      allow create: if isFacultyOrAdmin();
      // Anyone signed in can read logs
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // ── /bookings ───────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Students can read their own bookings
      allow read: if isSignedIn() 
        && (request.auth.uid == resource.data.studentId || isAdmin() || isFaculty());
      
      // Students can create booking requests
      allow create: if isSignedIn() 
        && isStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending';
      
      // Faculty can update (approve/decline) for their assigned resources
      // Admin can update any booking
      allow update: if (isAdmin()) 
        || (isFaculty() && request.resource.data.status in ['pending', 'approved', 'declined']);
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
  }
}